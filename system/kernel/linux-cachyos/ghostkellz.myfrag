# =========================
# ghostkellz.myfrag
# =========================

# --- Elgato / UVC webcam & media ---
CONFIG_MEDIA_SUPPORT=y
CONFIG_MEDIA_USB_SUPPORT=y
CONFIG_MEDIA_CAMERA_SUPPORT=y
CONFIG_MEDIA_CONTROLLER=y
CONFIG_VIDEO_DEV=m
CONFIG_USB_VIDEO_CLASS=m
CONFIG_V4L2_MEM2MEM_DEV=m
CONFIG_VIDEOBUF2_CORE=m
CONFIG_VIDEOBUF2_V4L2=m
CONFIG_INPUT_EVDEV=m
CONFIG_SND_USB_AUDIO=m

# --- CIFS/SMB ---
CONFIG_CIFS=m
CONFIG_CIFS_XATTR=y
CONFIG_CIFS_ACL=y
CONFIG_CIFS_DFS_UPCALL=y
CONFIG_CIFS_FSCACHE=y

# --- FUSE3 ---
CONFIG_FUSE_FS=m
CONFIG_FUSE_DAX=y
CONFIG_FUSE_USERSPACE_HELPER=y

# --- Namespaces & Cgroups (containers) ---
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_CGROUPS=y
CONFIG_NET_CLS_CGROUP=m

# --- OverlayFS (container layered fs) ---
CONFIG_OVERLAY_FS=m

# --- Container/VPN networking drivers ---
CONFIG_TUN=m
CONFIG_VETH=m
CONFIG_BRIDGE=m
CONFIG_BRIDGE_NETFILTER=m
CONFIG_MACVLAN=m
CONFIG_IPVLAN=m
CONFIG_VXLAN=m
CONFIG_GENEVE=m
CONFIG_WIREGUARD=m

# --- Netfilter / nftables + compat (IPv4/IPv6) ---
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CONNTRACK_MARK=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NF_NAT=y
CONFIG_NFT_NAT=m
CONFIG_NFT_CHAIN_NAT=m
CONFIG_NFT_CT=m
CONFIG_NFT_MASQ=m
CONFIG_NFT_REDIR=m
CONFIG_NFT_FIB=m
CONFIG_NFT_FIB_IPV4=m
CONFIG_NFT_FIB_INET=m
CONFIG_NFT_PKTTYPE=m
CONFIG_NFT_LOG=m
CONFIG_NFT_REJECT=m
# Additional nftables modules for Docker
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=m
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=m
CONFIG_NETFILTER_XT_MATCH_CGROUP=m
CONFIG_IP_NF_NAT=m
CONFIG_IP_NF_TARGET_REDIRECT=m
# CRITICAL: nftables compat layer for iptables (required for Docker with iptables-nft)
CONFIG_NFT_COMPAT=m
# iptables compat (some tools still use it)
CONFIG_IP_NF_IPTABLES=m
CONFIG_IP_NF_FILTER=m
CONFIG_IP_NF_TARGET_MASQUERADE=m
CONFIG_IP6_NF_IPTABLES=m
CONFIG_IP6_NF_FILTER=m
CONFIG_IP6_NF_TARGET_MASQUERADE=m
CONFIG_NF_NAT_IPV6=m
# CONNMARK - required for Tailscale packet marking
CONFIG_NETFILTER_XT_CONNMARK=m
CONFIG_NETFILTER_XT_TARGET_CONNMARK=m
CONFIG_NETFILTER_XT_MATCH_CONNMARK=m
CONFIG_NET_ACT_CONNMARK=m
# Docker bridge/ebtables
CONFIG_NETFILTER_XT_TARGET_CHECKSUM=m
CONFIG_NETFILTER_XT_TARGET_LOG=m
CONFIG_BRIDGE_NF_EBTABLES=m
CONFIG_BRIDGE_NF_EBTABLES_LEGACY=m
CONFIG_NF_CONNTRACK_BRIDGE=m

# --- IPv6 core (Battle.net/WoW prefers v6 when present) ---
CONFIG_IPV6=y
CONFIG_INET6_XFRM_MODE_TRANSPORT=m
CONFIG_INET6_XFRM_MODE_TUNNEL=m
CONFIG_INET6_XFRM_MODE_BEET=m

# --- TLS/crypto useful for Wine/Proton TLS 1.3 paths ---
CONFIG_TLS=y
CONFIG_CRYPTO_USER_API_TLS=y
CONFIG_CRYPTO_AES_X86_64=m
CONFIG_CRYPTO_AES_NI_INTEL=m
CONFIG_CRYPTO_CHACHA20_X86_64=m
CONFIG_CRYPTO_POLY1305_X86_64=m

# --- Futex (Proton esync/fsync baseline) ---
CONFIG_FUTEX=y

# --- Virtualization (KVM/QEMU) ---
CONFIG_KVM=y
CONFIG_KVM_AMD=m
CONFIG_KVM_INTEL=m
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=m
CONFIG_VIRTIO_NET=m
CONFIG_VIRTIO_BLK=m
CONFIG_VIRTIO_CONSOLE=m
CONFIG_VIRTIO_BALLOON=m
CONFIG_VIRTIO_GPU=m
CONFIG_VIRTIO_INPUT=m
CONFIG_VIRTIO_VSOCKETS=m
CONFIG_VIRTIO_FS=m

# --- Passthrough (VFIO) ---
CONFIG_VFIO=y
CONFIG_VFIO_PCI=y
CONFIG_VFIO_VIRQFD=y
CONFIG_VFIO_MDEV=m

# --- Optional virt nic baked-in (you had y before; m is fine too) ---
CONFIG_VIRTIO_NET=y

# =========================
# Performance & Optimization
# =========================

# --- AMD Zen5 specific optimizations ---
CONFIG_X86_AMD_PLATFORM_DEVICE=y
CONFIG_AMD_NB=y
CONFIG_AMD_IOMMU=y
CONFIG_AMD_IOMMU_V2=m

# --- High-end system tuning (64GB RAM, many cores) ---
CONFIG_NR_CPUS=32
CONFIG_NUMA=y
CONFIG_NUMA_BALANCING=y
CONFIG_NUMA_BALANCING_DEFAULT_ENABLED=y

# --- Transparent Hugepages (performance for large memory workloads) ---
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y

# --- Memory compaction ---
CONFIG_COMPACTION=y
CONFIG_MIGRATION=y

# --- Zstd compression (faster than default) ---
CONFIG_KERNEL_ZSTD=y
CONFIG_ZSTD_COMPRESS=y
CONFIG_ZSTD_DECOMPRESS=y

# --- BPF JIT for performance ---
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y

# --- High resolution timers ---
CONFIG_HIGH_RES_TIMERS=y

# --- NVIDIA support (RTX 5090 Blackwell) ---
# Note: RTX 5090 (Blackwell) REQUIRES nvidia-open driver (570.x+)
# Nouveau does not support Blackwell architecture
CONFIG_DRM=y
CONFIG_DRM_NOUVEAU=m
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y
# fbdev required for Linux 6.11+ with NVIDIA proprietary drivers
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_SYSFB_SIMPLEFB=y

# --- USB optimization (high-speed devices) ---
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y

# --- NVMe optimizations ---
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_CORE=y
CONFIG_NVME_MULTIPATH=y

# --- libvirt essentials ---
CONFIG_VHOST=y
CONFIG_VHOST_NET=y
CONFIG_VHOST_VSOCK=y
CONFIG_VHOST_VDPA=y

# --- Additional container features ---
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_SCHED=y
# IP Virtual Server (Docker Swarm/load balancing)
CONFIG_IP_VS=m
CONFIG_IP_VS_PROTO_TCP=y
CONFIG_IP_VS_PROTO_UDP=y
CONFIG_IP_VS_RR=m
CONFIG_IP_VS_NFCT=y
CONFIG_NETFILTER_XT_MATCH_IPVS=m

# --- Security namespaces for containers ---
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# --- AppArmor (used by Docker) ---
CONFIG_SECURITY_APPARMOR=y

# =========================
# AMD GPU (Ryzen 9950X3D integrated Radeon)
# =========================
# Keep AMDGPU enabled - required for iGPU and system stability
CONFIG_DRM_AMDGPU=m
CONFIG_DRM_AMDGPU_SI=y
CONFIG_DRM_AMDGPU_CIK=y
CONFIG_DRM_AMDGPU_USERPTR=y

# =========================
# NVIDIA Container Toolkit / Docker GPU Support
# =========================
# Required for nvidia-container-toolkit (Ollama, etc.)
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_BPF=y

# =========================
# Tailscale / WireGuard VPN
# =========================
CONFIG_TUN=m
CONFIG_NET_UDP_TUNNEL=m
CONFIG_NETFILTER_XT_MATCH_COMMENT=m
CONFIG_NETFILTER_XT_TARGET_MARK=m
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_IP_ROUTE_MULTIPATH=y
CONFIG_IPV6_MULTIPLE_TABLES=y

