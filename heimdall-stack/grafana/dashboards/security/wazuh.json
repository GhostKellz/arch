      "targets": [ { "refId": "A", "datasource": { "type": "grafana-opensearch-datasource", "uid": "wazuh" }, "query": "rule.level:>=8 AND agent.name:$agent $query", "timeField": "timestamp", "metrics": [ { "id": "1", "type": "logs" } ], "bucketAggs": [] } ]
