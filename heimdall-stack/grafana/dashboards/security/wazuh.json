      "targets": [ { "refId": "A", "datasource": { "type": "grafana-opensearch-datasource", "uid": "wazuh" }, "query": "agent.name:$agent $query", "timeField": "timestamp", "metrics": [ { "id": "1", "type": "count" } ], "bucketAggs": [ { "id": "2", "type": "terms", "field": "rule.groups", "settings": { "order": "desc", "orderBy": "_count", "size": "10" } } ] } ]
