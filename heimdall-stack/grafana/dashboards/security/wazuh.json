      "targets": [ { "refId": "A", "datasource": { "type": "grafana-opensearch-datasource", "uid": "wazuh" }, "query": "agent.name:$agent $query", "timeField": "timestamp", "metrics": [ { "id": "1", "type": "cardinality", "field": "agent.id" } ], "bucketAggs": [ { "id": "2", "type": "date_histogram", "field": "timestamp", "settings": { "interval": "auto" } } ] } ]
    },
    {
