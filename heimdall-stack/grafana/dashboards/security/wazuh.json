{
  "uid": "heimdall-wazuh",
  "title": "Wazuh SIEM",
  "description": "Wazuh indexer (OpenSearch) @ 192.0.2.25:9200. Daily indices wazuh-alerts-4.x-*. Time field: timestamp.",
  "tags": ["heimdall", "security", "wazuh", "siem"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 0,
  "time": { "from": "now-24h", "to": "now" },
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "agent", "label": "Agent", "type": "query",
        "datasource": { "type": "grafana-opensearch-datasource", "uid": "wazuh" },
        "definition": "{\"find\": \"terms\", \"field\": \"agent.name\"}",
        "query": "{\"find\": \"terms\", \"field\": \"agent.name\"}",
        "includeAll": true, "multi": true, "allValue": "*", "refresh": 2, "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "query", "label": "Lucene filter", "type": "textbox", "query": "",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total alerts",
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "wazuh" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-opensearch-datasource", "uid": "wazuh" }, "query": "agent.name:$agent $query", "timeField": "timestamp", "metrics": [ { "id": "1", "type": "count" } ], "bucketAggs": [ { "id": "2", "type": "date_histogram", "field": "timestamp", "settings": { "interval": "auto" } } ] } ]
    },
    {
      "id": 2, "type": "stat", "title": "High severity (level >= 8)",
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "wazuh" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-opensearch-datasource", "uid": "wazuh" }, "query": "rule.level:>=8 AND agent.name:$agent $query", "timeField": "timestamp", "metrics": [ { "id": "1", "type": "count" } ], "bucketAggs": [ { "id": "2", "type": "date_histogram", "field": "timestamp", "settings": { "interval": "auto" } } ] } ]
    },
    {
