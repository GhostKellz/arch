# Bind the socket proxy to THIS host's Tailscale IP (tailnet-only reachability).
# Copy to .env next to docker-compose.yml and set the real address.
#
# Do NOT use 0.0.0.0 (exposes the Docker API to every interface) or 127.0.0.1
# (Uptime Kuma on another host can't reach it — this was the original Docker host
# misconfig where the proxy was effectively loopback-only).
SOCKET_PROXY_BIND_IP=100.64.0.40
