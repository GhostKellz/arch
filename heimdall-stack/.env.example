# Heimdall observability stack - environment template
# Copy to .env on the host and fill in real secrets. .env is gitignored.

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_strong
# Public URL Grafana generates links/redirects for. Behind the Reverse-proxy reverse
# proxy this is the friendly name (served tailscale-only); use the bare host:port
# if accessing Grafana directly.
GF_SERVER_ROOT_URL=https://grafana.example.com

# --- CrowdSec Postgres (loopback-only) ---
CROWDSEC_DB_NAME=crowdsec
CROWDSEC_DB_USER=crowdsec
CROWDSEC_DB_PASSWORD=change_me_db_strong

# --- Wazuh indexer (existing stack) for Grafana OpenSearch datasource ---
# Point at your Wazuh indexer; leave blank to skip provisioning the datasource.
WAZUH_INDEXER_URL=
WAZUH_INDEXER_USER=
WAZUH_INDEXER_PASSWORD=

# --- Image pins (override here to bump versions deliberately) ---
LOKI_VERSION=3.5.1
PROMETHEUS_VERSION=v3.4.1
ALERTMANAGER_VERSION=v0.28.1
GRAFANA_VERSION=11.6.1
NODE_EXPORTER_VERSION=v1.9.1
CADVISOR_VERSION=v0.52.1
CROWDSEC_VERSION=v1.6.8
POSTGRES_VERSION=16-alpine
